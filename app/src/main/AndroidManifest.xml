<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- فقط برای اندروید ۹ و پایین‌تر لازمه، اندروید ۱۰+ نیازی نداره -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- نمایش نوتیفیکیشن در اندروید ۱۳ به بالا -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- برای اینکه پخش موزیک با نوتیفیکیشن قابل‌کنترل باشه و حتی با رفتن اپ به پس‌زمینه قطع نشه -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application
        android:allowBackup="true"
        android:largeHeap="true"
        android:label="دهات"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.DehaatKiosk"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.DehaatKiosk">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- سرویس دریافت پوش نوتیفیکیشن -->
        <service
            android:name=".DehaatFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- سرویسِ فورگراندی که نوتیفیکیشنِ پخشِ موزیک (پلی/پاز/قبلی/بعدی) رو نگه می‌داره -->
        <service
            android:name=".MediaPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@android:drawable/ic_dialog_info" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="dehaat_notifications" />
    </application>
</manifest>
